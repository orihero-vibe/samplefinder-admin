# Staging Appwrite environment for the admin dashboard.
# Copy to .env.staging and fill in values. .env.staging is gitignored.
#
# KEY FACT: staging is identical to prod EXCEPT VITE_APPWRITE_PROJECT_ID.
# The staging project was provisioned by pushing the same appwrite.config.json,
# which pins explicit resource ids — so the database id, collection slugs,
# storage bucket id, and function ids are the SAME in both projects.
# Fastest path: copy your prod .env and change only VITE_APPWRITE_PROJECT_ID.
#
# Use:  npm run dev:staging       (local dev pointed at staging Appwrite)
#       npm run build:staging     (production build pointed at staging Appwrite)

VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=6a0ad92e0001d5e515ce
VITE_APPWRITE_PROJECT_NAME=Samplefinder (Staging)
VITE_APPWRITE_DATABASE_ID=69217af50038b9005a61

# Collection slugs — identical to prod (the app also falls back to these slugs)
VITE_APPWRITE_COLLECTION_USERS=
VITE_APPWRITE_COLLECTION_USER_PROFILES=user_profiles
VITE_APPWRITE_COLLECTION_CLIENTS=clients
VITE_APPWRITE_COLLECTION_EVENTS=events
# Leave unset (defaults to true). Set to false ONLY if the events table lacks a locationId column.
# VITE_APPWRITE_EVENTS_HAS_LOCATION_ID=true
VITE_APPWRITE_COLLECTION_TRIVIA=trivia
VITE_APPWRITE_COLLECTION_REVIEWS=reviews
VITE_APPWRITE_COLLECTION_CHECKINS=checkins
VITE_APPWRITE_COLLECTION_REPORTS=
VITE_APPWRITE_COLLECTION_REPORT_LOGS=
VITE_APPWRITE_COLLECTION_NOTIFICATIONS=notifications
VITE_APPWRITE_COLLECTION_CATEGORIES=categories
VITE_APPWRITE_COLLECTION_POPUPS=popups

# Storage bucket — identical to prod
VITE_APPWRITE_STORAGE_BUCKET_ID=6921b4ae002feef4b15e

# Function IDs — identical to prod
VITE_APPWRITE_MOBILE_API_FUNCTION_ID=69308117000e7a96bcbb
VITE_APPWRITE_STATISTICS_FUNCTION_ID=69341ffa001a4ebd28c2
VITE_APPWRITE_NOTIFICATION_FUNCTION_ID=695d55bb002bc6b75430

# Feature flags
VITE_ENABLE_TRIVIA_CUSTOM_SCHEDULE=false
